<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <!-- Foto Profil Bulat -->
    <com.google.android.material.imageview.ShapeableImageView
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/foto_profil"
        android:scaleType="centerCrop"
        android:layout_marginBottom="16dp"
        app:shapeAppearanceOverlay="@style/CircleShapeOverlay"
        app:strokeWidth="2dp"
        app:strokeColor="?attr/colorPrimary" />

    <!-- Nama -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/profil_nama"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">
        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="NIM"
            android:textStyle="bold"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=": " />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profil_nim"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">
        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="Kelas"
            android:textStyle="bold"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=": " />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profil_kelas"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="Matkul"
            android:textStyle="bold"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=": " />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profil_matkul"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
    </LinearLayout>

</LinearLayout>